// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Church {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  description   String?
  theme         String
  modules       String
  plan          String   @default("starter")
  // 위치 및 연락처 정보
  address       String?
  phone         String?
  email         String?
  parking       String?
  mapLat        Float?
  mapLng        Float?
  // 교회 소개
  intro         String?   // 교회 소개 (긴 텍스트)
  vision        String?   // 비전
  history       String?   // 교회 역사
  pastorName    String?   // 담임목사명
  pastorMessage String?   // 담임목사 인사말
  pastorImage   String?   // 담임목사 사진 URL
  // 예배 시간 (JSON)
  worshipTimes  String?   // 예배 시간 JSON
  // 히어로 배너
  heroTitle     String?   // 히어로 제목
  heroSubtitle  String?   // 히어로 부제목
  heroImage     String?   // 히어로 배경 이미지 URL
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  users         User[]
  sermons       Sermon[]
  notices       Notice[]
  schedules     Schedule[]
  galleries     Gallery[]
  posts         Post[]
  boards        Board[]
  categories    Category[]
  churchPlugins ChurchPlugin[]
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  role      String    @default("member") // super_admin, church_admin, editor, member
  churchId  String?
  church    Church?   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Sermon {
  id          String   @id @default(cuid())
  title       String
  content     String
  speaker     String
  date        DateTime @default(now())
  youtubeUrl  String?  // YouTube 영상 URL (선택)
  thumbnail   String?  // 썸네일 이미지 URL (선택)
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  content     String
  imageUrl    String?   // 첨부 이미지
  pinned      Boolean   @default(false)
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Schedule {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  category    String   @default("general") // general, worship, event, meeting, education
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Gallery {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  category    String?   // worship, event, community 등
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Post {
  id          String    @id @default(cuid())
  title       String
  content     String
  imageUrl    String?    // 첨부 이미지
  category    String    @default("general")
  pinned      Boolean   @default(false)
  authorName  String?
  boardId     String?
  board       Board?    @relation(fields: [boardId], references: [id], onDelete: SetNull)
  churchId    String
  church      Church    @relation(fields: [churchId], references: [id], onDelete: Cascade)
  comments    Comment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  authorName  String?
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Board {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  icon        String?   // 이모지
  order       Int      @default(0)
  allowWrite  String   @default("all") // all, admin_only, closed
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  posts       Post[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([churchId, slug])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String
  icon        String?   // 이모지
  color       String?   // hex color
  order       Int      @default(0)
  type        String   @default("gallery") // gallery, post
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([churchId, slug, type])
}

// 플러그인 레지스트리 (시스템 전체)
model Plugin {
  id          String   @id @default(cuid())
  name        String   @unique              // "hero-video"
  type        String                       // "section" | "feature" | "theme" | "widget"
  label       String                       // 표시명
  description String   @default("")
  version     String   @default("1.0.0")
  icon        String   @default("📦")
  config      String   @default("{}")       // 기본 설정 JSON
  configSchema String  @default("[]")       // 설정 UI 스키마 JSON
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  churchPlugins ChurchPlugin[]
}

// 교회별 활성화된 플러그인
model ChurchPlugin {
  id          String   @id @default(cuid())
  churchId    String
  pluginId    String
  enabled     Boolean  @default(true)
  config      String   @default("{}")       // 교회별 오버라이드 설정 JSON
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  plugin      Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([churchId, pluginId])
}
