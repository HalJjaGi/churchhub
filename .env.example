# ChurchHub 환경 변수 예시
# 복사해서 .env로 사용: cp .env.example .env

# 데이터베이스
# 로컬 Docker: postgresql://churchhub:churchhub_password@localhost:5433/churchhub
# Docker 내부: postgresql://churchhub:churchhub_password@churchhub-db:5432/churchhub
DATABASE_URL="postgresql://churchhub:churchhub_password@localhost:5433/churchhub?schema=public"

# 인증 (반드시 변경: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-key-here"
AUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3002"
AUTH_URL="http://localhost:3002"
